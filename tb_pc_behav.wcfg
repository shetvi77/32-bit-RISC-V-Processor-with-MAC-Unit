<?xml version="1.0" encoding="UTF-8"?>
<wave_config>
   <wave_state>
   </wave_state>
   <db_ref_list>
      <db_ref path="tb_pc_behav.wdb" id="1">
         <top_modules>
            <top_module name="glbl" />
            <top_module name="tb_pc" />
         </top_modules>
      </db_ref>
   </db_ref_list>
   <zoom_setting>
      <ZoomStartTime time="0.000 ns"></ZoomStartTime>
      <ZoomEndTime time="70.001 ns"></ZoomEndTime>
      <Cursor1Time time="70.000 ns"></Cursor1Time>
   </zoom_setting>
   <column_width_setting>
      <NameColumnWidth column_width="165"></NameColumnWidth>
      <ValueColumnWidth column_width="186"></ValueColumnWidth>
   </column_width_setting>
   <WVObjectSize size="4" />
   <wvobject fp_name="/tb_pc/clk" type="logic">
      <obj_property name="ElementShortName">clk</obj_property>
      <obj_property name="ObjectShortName">clk</obj_property>
   </wvobject>
   <wvobject fp_name="/tb_pc/reset" type="logic">
      <obj_property name="ElementShortName">reset</obj_property>
      <obj_property name="ObjectShortName">reset</obj_property>
   </wvobject>
   <wvobject fp_name="/tb_pc/PCNext" type="array">
      <obj_property name="ElementShortName">PCNext[31:0]</obj_property>
      <obj_property name="ObjectShortName">PCNext[31:0]</obj_property>
   </wvobject>
   <wvobject fp_name="/tb_pc/PC" type="array">
      <obj_property name="ElementShortName">PC[31:0]</obj_property>
      <obj_property name="ObjectShortName">PC[31:0]</obj_property>
   </wvobject>
</wave_config>
